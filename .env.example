# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your local PostgreSQL credentials.
#
#   Local run (no Docker):  DB_HOST=localhost
#   Docker run:             DB_HOST=host.docker.internal
# ─────────────────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=ProjectA

# JWT — use a long random string in any environment that handles real users.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
